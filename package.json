{
  "name": "pi-vscode",
  "displayName": "Pi Coding Agent",
  "version": "0.0.9",
  "description": "VS Code extension for pi coding agent",
  "categories": [
    "AI",
    "Chat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pi0/pi-vscode"
  },
  "publisher": "pi0",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts -w",
    "package": "pnpm build && pnpx @vscode/vsce package --no-dependencies",
    "install-local": "pnpm package && code --install-extension *.vsix",
    "release": "node scripts/release.ts",
    "fmt": "oxlint . --fix && oxfmt .",
    "lint": "oxlint . && oxfmt --check .",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "test": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.9",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown": "^1.0.0-rc.10",
    "vitest": "^4.1.0"
  },
  "contributes": {
    "icons": {
      "pi-logo": {
        "description": "Pi logo icon",
        "default": {
          "fontPath": "assets/fonts/pi-icons.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "commands": [
      {
        "command": "pi-vscode.open",
        "title": "Pi: Open",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "pi-vscode.upgrade",
        "title": "Pi: Upgrade Pi"
      },
      {
        "command": "pi-vscode.openInNewWindow",
        "title": "Pi: Open in New Window",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pi-vscode.open",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pi",
          "title": "Pi",
          "icon": "assets/logo.svg"
        }
      ]
    },
    "views": {
      "pi": [
        {
          "type": "webview",
          "id": "pi-vscode.sessions",
          "name": "Sessions"
        },
        {
          "type": "webview",
          "id": "pi-vscode.models",
          "name": "Models"
        },
        {
          "type": "webview",
          "id": "pi-vscode.settings",
          "name": "Settings",
          "visibility": "collapsed"
        }
      ]
    },
    "configuration": {
      "title": "Pi",
      "properties": {
        "pi-vscode.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the pi binary. Leave empty for auto-detection."
        },
        "pi-vscode.shell": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the shell executable for launching pi. Leave empty to use VS Code's default terminal profile."
        },
        "pi-vscode.env": {
          "type": "object",
          "default": {},
          "description": "Environment variables to set in the pi terminal session."
        },
        "pi-vscode.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to pi."
        }
      }
    },
    "keybindings": [
      {
        "command": "pi-vscode.open",
        "key": "alt+shift+p"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "packageManager": "pnpm@10.32.1"
}
