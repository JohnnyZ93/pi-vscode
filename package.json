{
  "name": "pi-agent-studio",
  "displayName": "Pi Agent Studio",
  "version": "1.0.0",
  "description": "Pi coding agent in VS Code — native terminal TUI with a visual sidebar to manage sessions, models, and settings. No GUI wrapper, full editor bridge.",
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "agent",
    "ai",
    "ai-assistant",
    "anthropic",
    "chat",
    "claude",
    "coding-agent",
    "gemini",
    "llm",
    "openai",
    "pi",
    "pi-agent",
    "pi-coding-agent",
    "terminal",
    "tui"
  ],
  "bugs": {
    "url": "https://github.com/JohnnyZ93/pi-agent-studio/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JohnnyZ93/pi-agent-studio"
  },
  "publisher": "johnny-zhao",
  "type": "module",
  "main": "./dist/extension.cjs",
  "scripts": {
    "build": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts -w",
    "package": "pnpm build && pnpx @vscode/vsce package --no-dependencies",
    "install-local": "pnpm package && code --install-extension *.vsix",
    "release": "node scripts/release.ts",
    "fmt": "oxlint . --fix && oxfmt .",
    "lint": "oxlint . && oxfmt --check .",
    "typecheck": "tsgo --noEmit --skipLibCheck",
    "test": "pnpm lint && pnpm typecheck"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.9",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rolldown": "^1.0.0-rc.10",
    "vitest": "^4.1.0"
  },
  "contributes": {
    "icons": {
      "pi-logo": {
        "description": "Pi logo icon",
        "default": {
          "fontPath": "assets/fonts/pi-icons.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "commands": [
      {
        "command": "pi-agent-studio.open",
        "title": "Pi: Open",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      },
      {
        "command": "pi-agent-studio.upgrade",
        "title": "Pi: Upgrade Pi"
      },
      {
        "command": "pi-agent-studio.openSettingsJson",
        "title": "Pi: Open settings.json"
      },
      {
        "command": "pi-agent-studio.openModelsJson",
        "title": "Pi: Open models.json"
      },
      {
        "command": "pi-agent-studio.openInNewWindow",
        "title": "Pi: Open in New Window",
        "icon": {
          "light": "assets/logo-light.svg",
          "dark": "assets/logo.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pi-agent-studio.open",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pi",
          "title": "Pi",
          "icon": "assets/logo.svg"
        }
      ]
    },
    "views": {
      "pi": [
        {
          "type": "webview",
          "id": "pi-agent-studio.sessions",
          "name": "Sessions"
        },
        {
          "type": "webview",
          "id": "pi-agent-studio.models",
          "name": "Models"
        },
        {
          "type": "webview",
          "id": "pi-agent-studio.settings",
          "name": "Settings",
          "visibility": "collapsed"
        }
      ]
    },
    "configuration": {
      "title": "Pi",
      "properties": {
        "pi-agent-studio.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the pi binary. Leave empty for auto-detection."
        },
        "pi-agent-studio.env": {
          "type": "object",
          "default": {},
          "description": "Environment variables to set in the pi terminal session."
        },
        "pi-agent-studio.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra command-line arguments passed to pi."
        }
      }
    },
    "keybindings": [
      {
        "command": "pi-agent-studio.open",
        "key": "alt+shift+p"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "assets/icon.png",
  "badges": [
    {
      "url": "https://img.shields.io/github/stars/JohnnyZ93/pi-agent-studio?style=social",
      "description": "Star pi-agent-studio on Github",
      "href": "https://github.com/JohnnyZ93/pi-agent-studio"
    }
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "packageManager": "pnpm@10.32.1"
}
